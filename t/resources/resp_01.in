#!/usr/bin/env perl
use strict;
use warnings;

# ------------------------------------------------------------
# find_biggest_with_mount.pl
#
# Scans the whole filesystem (excluding pseudo fs) and reports:
#   * total number of regular files
#   * top N largest files with size, path, and the mount point they reside on
#
# Usage: perl find_biggest_with_mount.pl [TOP]
# ------------------------------------------------------------

sub human_bytes {
    my ($bytes) = @_;
    return sprintf("%.2f B", $bytes) if $bytes < 1024;
    $bytes /= 1024;
    return sprintf("%.2f KB", $bytes) if $bytes < 1024;
    $bytes /= 1024;
    return sprintf("%.2f MB", $bytes) if $bytes < 1024;
    $bytes /= 1024;
    return sprintf("%.2f GB", $bytes);
}

# Get mount point for a given path by checking /proc/self/mountinfo
sub get_mountpoint {
    my ($path) = @_;
    # Normalize path (remove trailing slashes except root)
    $path =~ s{/+$}{} unless $path eq '/';
    open my $mnt, '<', '/proc/self/mountinfo' or die "Cannot read /proc/self/mountinfo: $!";
    my ($best_len, $best_mp) = (0, '/');
    while (<$mnt>) {
        # format: 36 35 98:1 / /opt/rocm rw,relatime shared:1 - ext4 /dev/mapper/m.2-home rw
        # fields: ... mountpoint optional...
        # We'll parse the mountpoint (field 4) and the root of mount (field 3?) Actually easier:
        # Use `findmnt` but we avoid external deps; approximate by checking if path starts with mountpoint.
        my @parts = split;
        next unless @parts >= 5;
        my $mnt_point = $parts[4];
        if (index($path, $mnt_point) == 0 && length($mnt_point) > $best_len) {
            $best_len = length($mnt_point);
            $best_mp = $mnt_point;
        }
    }
    close $mnt;
    return $best_mp;
}

# Directories we skip entirely
my @SKIP_DIRS = qw(/proc /sys /dev /run);

sub is_skipped {
    my ($path) = @_;
    foreach my $skip (@SKIP_DIRS) {
        return 1 if index($path, $skip) == 0;
    }
    return 0;
}

# Determine how many top entries to show (default 20)
my $TOP = shift // 20;

print "Scanning filesystem... (this may take a moment)\n";
my @files = qx{
    find / -type f \\( \\
        -path '/proc' -prune -o \\
        -path '/sys'  -prune -o \\
        -path '/dev'  -prune -o \\
        -path '/run'  -prune -o \\
        -print \\
    \\) 2>/dev/null
};
chomp @files;
@files = grep { !is_skipped($_) } @files;

my $total = scalar @files;
print "Total regular files found (excluding pseudoÃ¢ÂÂfs): $total\n";

# Build list of [size, filepath]
my @sized;
foreach my $f (@files) {
    next unless -e $f && -r _;   # skip if we cannot stat/read
    push @sized, [ (stat($f))[7], $f ];
}

# Sort descending by size
@sized = sort { $b->[0] <=> $a->[0] } @sized;

print "\nTop $TOP largest files:\n";
for my $i (0 .. ($TOP-1 < @sized ? $TOP-1 : $#sized)) {
    my ($size, $path) = @{$sized[$i]};
    my $mp = get_mountpoint($path);
    printf "%4d: %12s (%s)  [%s]\n", $i+1, human_bytes($size), $path, $mp;
}

# Also compute total size of /opt/rocm if it exists
if (-d '/opt/rocm') {
    my $opt_size = qx{du -sb /opt/rocm 2>/dev/null};
    chomp $opt_size;
    $opt_size =~ s/\s.*//;
    $opt_size //= 0;
    print "\nApproximate total size of /opt/rocm: ", human_bytes($opt_size), "\n";
}

__END__
